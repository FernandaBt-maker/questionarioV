{
  "version": 2,
  "buildCommand": "npm install",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1.js"
    },
    {
      "src": "/style.css",
      "dest": "/style.css"
    },
    {
      "src": "/script.js",
      "dest": "/script.js"
    },
    {
      "src": "/main.html",
      "dest": "/main.html"
    },
    {
      "src": "/",
      "dest": "/main.html"
    }
  ]
}